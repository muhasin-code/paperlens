# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
GRADIO_PORT=7860


# --- Paths ---
DATA_DIR=./data
CHROMA_PERSIST_DIR=./data/chroma
BM25_INDEX_PATH=./data/bm25_index.pkl
PROCESSED_CHUNKS_PATH=./data/processed/chunks.parquet


# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi4-mini


# --- Embeddings & Retrieval ---
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
CHUNK_SIZE_TOKENS=600
CHUNK_OVERLAP_TOKENS=100


# --- arXiv ingestation (Phase 01) ---
ARXIVE_MAX_RESULTS=500
ARXIVE_CATEGORY=cs.LG
# Examples: cs.LG, cs.CL, cs.AI - pick one subfield in Milestone 1.1


# --- Fine-tuned extractor (Phase 03) ---
HF_HUB_MODEL_ID=
# Base: Qwen/Qwen2.5-3B-Instruct; adapter path on hub after fine-tuning
EXTRACTION_ADAPTOR_REPO=
HF_TOKEN=
# Optional - only needed to push/pull private Hub assets


# --- Langfuse (Phase 04)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000


# --- Evaluation (Phase 04) ---
RAGAS_FAITHFULNESS_THRESHOLD=0.75
GOLD_DATASET_PATH=./eval/gold_dataset.jsonl


# --- Prompts ---
PROMPTS_DIR=./configs/prompts
PROMPT_VERSION=v1